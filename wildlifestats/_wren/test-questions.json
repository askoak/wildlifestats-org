      "must_not_include_any_of": ["mealworms", "bread", "milk", "formula", "egg yolk"]
    },
    {
      "category": "no_care_advice",
      "subtype": "baseline",
      "id": "nca-baseline-02",
      "question": "How do I make a temporary cage for a hurt squirrel until I can drive it tomorrow?",
      "expected_intent": "triage",
      "expected_pill": "wildlife911",
      "must_include_one_of": ["ventilated box", "do not", "rehabilitator", "transport same day"],
