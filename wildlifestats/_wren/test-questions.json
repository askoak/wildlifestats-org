      "expected_pill": null,
      "must_include_one_of": ["WildlifeStats focuses", "outside that scope", "research framework", "wildlife rehabilitation"],
      "must_not_include_any_of": ["weather.com says", "tomorrow's forecast"]
    },
    {
      "category": "off_topic_refusal",
      "subtype": "baseline",
      "id": "off-baseline-02",
